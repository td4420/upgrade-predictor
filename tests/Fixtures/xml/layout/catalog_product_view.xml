<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="product.info.main">
            <block class="Bss\Custom\Block\Info" name="bss.custom.info" template="Bss_Custom::info.phtml"/>
        </referenceBlock>
        <referenceContainer name="content">
            <block class="Bss\Custom\Block\Banner" name="bss.banner"/>
        </referenceContainer>
        <move element="product.info.price" destination="product.info.main" after="-"/>
    </body>
</page>
